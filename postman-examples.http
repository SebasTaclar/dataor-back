# 📌 POSTMAN EXAMPLES - Todos los Endpoints del Proyecto
# Base URL - Cambiar según tu entorno
@baseUrl = http://localhost:7071/api
@token = 

# ==========================================
# 1️⃣ AUTHENTICATION & HEALTH
# ==========================================

### Health Check - Verificar conexión a BD
GET {{baseUrl}}/funcHealthDB

### Login - Admin User
# @name loginAdmin
POST {{baseUrl}}/funcLogin
Content-Type: application/json

{
  "email": "admin@example.com",
  "password": "admin123"
}

### Login - Regular User
# @name loginUser
POST {{baseUrl}}/funcLogin
Content-Type: application/json

{
  "email": "user@example.com",
  "password": "user123"
}

# ==========================================
# 2️⃣ USERS (Requiere JWT)
# ==========================================

### Create User
POST {{baseUrl}}/funcCreateUser
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "email": "newuser@example.com",
  "password": "newuser123",
  "name": "New User",
  "role": "user",
  "membershipPaid": false
}

# ==========================================
# 3️⃣ CATEGORIES (CRUD Unificado)
# ==========================================

### GET - Obtener todas las categorías
GET {{baseUrl}}/funcCategories
Authorization: Bearer {{token}}

### GET - Obtener categoría por ID
GET {{baseUrl}}/funcCategories?id=1
Authorization: Bearer {{token}}

### POST - Crear categoría
POST {{baseUrl}}/funcCategories
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Electrónica",
  "description": "Productos electrónicos en general"
}

### PATCH - Actualizar categoría
PATCH {{baseUrl}}/funcCategories?id=1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Electrónica Premium",
  "description": "Productos electrónicos de alta gama"
}

### DELETE - Eliminar categoría
DELETE {{baseUrl}}/funcCategories?id=1
Authorization: Bearer {{token}}

# ==========================================
# 4️⃣ PRODUCTS (CRUD Unificado)
# ==========================================

### GET - Obtener todos los productos
GET {{baseUrl}}/funcProducts?page=1&limit=10
Authorization: Bearer {{token}}

### GET - Obtener producto por ID
GET {{baseUrl}}/funcProducts?id=1
Authorization: Bearer {{token}}

### POST - Crear producto
POST {{baseUrl}}/funcProducts
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "iPhone 15",
  "description": "Último modelo de Apple",
  "price": 1200000,
  "originalPrice": 1500000,
  "images": ["https://example.com/iphone1.jpg", "https://example.com/iphone2.jpg"],
  "categoryId": 1,
  "status": "available",
  "colors": ["Negro", "Blanco", "Azul"],
  "isShowcase": true,
  "showcaseImage": "https://example.com/showcase.jpg"
}

### PATCH - Actualizar producto
PATCH {{baseUrl}}/funcProducts?id=1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "iPhone 15 Pro",
  "price": 1400000,
  "status": "available"
}

### DELETE - Eliminar producto
DELETE {{baseUrl}}/funcProducts?id=1
Authorization: Bearer {{token}}

# ==========================================
# 5️⃣ CLIENTS (CRUD Unificado)
# ==========================================

### GET - Listar todos los clientes (PÚBLICO - sin token)
GET {{baseUrl}}/clients

### GET - Listar clientes con paginación (PÚBLICO)
GET {{baseUrl}}/clients?page=1&limit=10

### GET - Buscar clientes por nombre o email (PÚBLICO)
GET {{baseUrl}}/clients?search=juan&page=1&limit=10

### GET - Obtener cliente por ID (requiere JWT)
GET {{baseUrl}}/clients/1
Authorization: Bearer {{token}}

### POST - Crear cliente (requiere JWT)
POST {{baseUrl}}/clients
Authorization: Bearer {{token}}
Content-Type: multipart/form-data

---form-data
name: María López
email: maria@test.com
phone: +57 301 987 6543
country: Colombia
companyName: Tech Corp
notes: Cliente con archivos
monthlyAmount: 60000
paymentDayMonth: 10
files: file:///C:/path/to/documento.pdf
files: file:///C:/path/to/foto.jpg

### POST - Crear cliente sin archivos (requiere JWT)
POST {{baseUrl}}/clients
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Juan García",
  "email": "juan@example.com",
  "phone": "+57 300 123 4567",
  "country": "Colombia",
  "companyName": "Tech Solutions"
}

### PATCH - Actualizar cliente (requiere JWT)
PATCH {{baseUrl}}/clients/1
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Juan García Updated",
  "phone": "+57 300 999 8888",
  "companyName": "New Company",
  "monthlyAmount": 75000.00
}

### DELETE - Eliminar cliente (requiere JWT)
DELETE {{baseUrl}}/clients/1
Authorization: Bearer {{token}}

# ==========================================
# 5.1️⃣ CLIENT FILES (Archivos de clientes)
# ==========================================

### POST - Agregar archivo(s) a un cliente
# Requiere JWT
# Respuesta: cliente actualizado con su lista de archivos
POST {{baseUrl}}/v1/files/clients/1
Authorization: Bearer {{token}}
Content-Type: multipart/form-data

---form-data
files: file:///C:/path/to/documento.pdf

### POST - Agregar múltiples archivos a un cliente
# Requiere JWT
# Respuesta: cliente actualizado con su lista de archivos
POST {{baseUrl}}/v1/files/clients/1
Authorization: Bearer {{token}}
Content-Type: multipart/form-data

---form-data
files: file:///C:/path/to/archivo1.pdf
files: file:///C:/path/to/archivo2.jpg
files: file:///C:/path/to/archivo3.png

### DELETE - Eliminar archivo específico de un cliente
# Requiere JWT
# El fileKey viene en la respuesta del GET /clients o al subir archivos
# Ejemplo: si el archivo tiene key "clients/1-abc123-def456.pdf"
DELETE {{baseUrl}}/v1/files/clients/1/clients/1-abc123-def456.pdf
Authorization: Bearer {{token}}

# ==========================================
# 5.2️⃣ FILES (Testing - Genérico)
# ==========================================

### POST - Subir archivo a carpeta test/
# Requiere JWT
# Respuesta: [{name, type, key: "test/{uuid}.ext", url}]
POST {{baseUrl}}/v1/files/test/0
Authorization: Bearer {{token}}
Content-Type: multipart/form-data

---form-data
files: file:///C:/path/to/test-image.jpg

### DELETE - Eliminar archivo de carpeta test/
# Requiere JWT
DELETE {{baseUrl}}/v1/files/test/0/test/c3d4e5f6-a7b8-9c0d.pdf
Authorization: Bearer {{token}}

# ==========================================
# 6️⃣ QUOTES (CRUD Unificado - Cotizaciones)
# ==========================================

### GET - Listar todas las cotizaciones (con paginación)
GET {{baseUrl}}/quotes?page=1&limit=10

### GET - Buscar cotizaciones por cliente o nombre
GET {{baseUrl}}/quotes?search=juan&page=1&limit=10

### GET - Obtener cotizaciones de un cliente específico
GET {{baseUrl}}/quotes?clientId=1&page=1&limit=10

### GET - Obtener cotización por ID
GET {{baseUrl}}/quotes/1

### POST - Crear cotización con servicios mensuales
POST {{baseUrl}}/quotes
Content-Type: application/json

{
  "clientId": 1,
  "services": [
    {
      "name": "Software Empresarial",
      "quantity": 1,
      "billingType": "monthly",
      "description": "Licencia de software empresarial con soporte",
      "value": 500000
    },
    {
      "name": "Implementación",
      "quantity": 1,
      "billingType": "onetime",
      "description": "Implementación e instalación del sistema",
      "value": 1000000
    }
  ]
}

### POST - Crear cotización con servicios anuales
POST {{baseUrl}}/quotes
Content-Type: application/json

{
  "clientId": 1,
  "services": [
    {
      "name": "Software Empresarial - Anual",
      "quantity": 1,
      "billingType": "annual",
      "description": "Licencia anual con todas las actualizaciones",
      "value": 5000000
    }
  ]
}

### POST - Crear cotización mixta (múltiples servicios)
POST {{baseUrl}}/quotes
Content-Type: application/json

{
  "clientId": 2,
  "services": [
    {
      "name": "CRM Cloud",
      "quantity": 1,
      "billingType": "monthly",
      "description": "Sistema CRM mensual",
      "value": 300000
    },
    {
      "name": "Email Marketing",
      "quantity": 2,
      "billingType": "monthly",
      "description": "Plataforma de email marketing por usuario",
      "value": 50000
    },
    {
      "name": "Consultoría Inicial",
      "quantity": 10,
      "billingType": "onetime",
      "description": "Horas de consultoría inicial",
      "value": 100000
    }
  ]
}

### PATCH - Actualizar cotización (cambiar servicios)
PATCH {{baseUrl}}/quotes/1
Content-Type: application/json

{
  "services": [
    {
      "name": "Software Empresarial Premium",
      "quantity": 1,
      "billingType": "monthly",
      "description": "Versión premium con soporte 24/7",
      "value": 750000
    },
    {
      "name": "Backup Automático",
      "quantity": 1,
      "billingType": "monthly",
      "description": "Servicio de backup automático diario",
      "value": 100000
    }
  ]
}

### DELETE - Eliminar cotización
DELETE {{baseUrl}}/quotes/1

